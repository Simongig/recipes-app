# Copy this file to backend/.env for local development.
# Never commit real credentials — this file documents required variables only.

# Local dev (with docker-compose MongoDB):
MONGODB_URI=mongodb://localhost:27017/database

# Or your Atlas URI for prod:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

MONGODB_DATABASE=database

# Generate a secure random value for prod, e.g.:
#   openssl rand -base64 32
JWT_SECRET=replace-with-a-secure-random-string
